// DanceHAP version header (generated by CMake).
// Do not edit — values come from CMakeLists.txt project() directives.

#pragma once

#define DANCEHAP_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define DANCEHAP_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define DANCEHAP_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define DANCEHAP_VERSION_STRING "@PROJECT_VERSION@"

/// Plugin version as a packed OBS-style uint32 (major << 24 | minor << 16 | patch).
#define DANCEHAP_VERSION_UINT32 \
    ((DANCEHAP_VERSION_MAJOR << 24) | (DANCEHAP_VERSION_MINOR << 16) | (DANCEHAP_VERSION_PATCH))
